# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OpenAI (Narration, TTS, Portraits) ──────────────────────────────────────
# Server-side only — never expose to the client
NARRATOR_AI_API_KEY=

# Optional: override the default model (default: gpt-4o)
# NARRATOR_AI_MODEL=gpt-4o
